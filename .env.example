# API (porta 3001 padrão; use 3002 se já houver outro serviço na 3001)
PORT=3002

# Banco de dados
DATABASE_URL=postgresql://bella:bella@localhost:5432/bella_ai

# Infraestrutura
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://bella:bella@localhost:5672
QDRANT_URL=http://localhost:6333

# Autenticação
JWT_SECRET=troque-este-segredo
JWT_EXPIRES_IN=1d

# Inteligência da Bella — escolha UMA opção de custo zero:
#  A) Gemini gratuito (sem cartão): https://aistudio.google.com/apikey
GOOGLE_API_KEY=
#  B) Ollama local (sem conta): instale o Ollama e use as duas linhas abaixo
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
#  C) Anthropic/Claude (pago, opcional)
ANTHROPIC_API_KEY=
# Forçar provedor (gemini | ollama | anthropic | mock). Vazio = automático.
AI_PROVIDER=

# Canais
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
META_WEBHOOK_VERIFY_TOKEN=

# Motor de reservas do hotel (geração de link) — sistema Silbeck
BOOKING_ENGINE_BASE_URL=https://sbreserva.silbeck.com.br/hotelbosque
BOOKING_ENGINE_PATH=/pt-br/reserva
